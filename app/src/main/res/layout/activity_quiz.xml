<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_bg">

    <!-- Konten Utama Kuis (Komponen Pertanyaan & Tombol Pilihan) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Indikator Nomor Soal -->
        <TextView
            android:id="@+id/tvQuestionNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pertanyaan: 1 / 5"
            android:textColor="@color/brown_light"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <!-- Komponen Box Soal (Card View) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/cream_card"
            android:padding="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/tvQuestionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ini adalah tempat teks pertanyaan kuis dari BrainPlay akan muncul?"
                android:textColor="@color/brown_dark"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>

        <!-- Pilihan Jawaban A -->
        <Button
            android:id="@+id/btnOptionA"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Pilihan Jawaban A"
            android:textColor="@color/brown_dark"
            android:backgroundTint="@color/cream_accent"
            android:layout_marginBottom="12dp"
            android:textAllCaps="false" />

        <!-- Pilihan Jawaban B -->
        <Button
            android:id="@+id/btnOptionB"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Pilihan Jawaban B"
            android:textColor="@color/brown_dark"
            android:backgroundTint="@color/cream_accent"
            android:layout_marginBottom="12dp"
            android:textAllCaps="false" />

        <!-- Pilihan Jawaban C -->
        <Button
            android:id="@+id/btnOptionC"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Pilihan Jawaban C"
            android:textColor="@color/brown_dark"
            android:backgroundTint="@color/cream_accent"
            android:layout_marginBottom="12dp"
            android:textAllCaps="false" />

        <!-- Pilihan Jawaban D -->
        <Button
            android:id="@+id/btnOptionD"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Pilihan Jawaban D"
            android:textColor="@color/brown_dark"
            android:backgroundTint="@color/cream_accent"
            android:layout_marginBottom="32dp"
            android:textAllCaps="false" />

    </LinearLayout>

    <!-- TIRAI LOADING SCREEN (Aktif saat aplikasi sedang mengambil data) -->
    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cream_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/brown_dark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Memuat Kuis..."
            android:textColor="@color/brown_dark"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- MANDATORY SPEC: TIRAI KONDISI GAGAL JARINGAN DAN TOMBOL REFRESH (Poin 6 Spesifikasi) -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cream_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gagal Memuat Data"
            android:textColor="@color/brown_dark"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Koneksi internet terputus. Silakan periksa jaringan Anda atau coba muat ulang."
            android:textColor="@color/brown_light"
            android:textSize="14sp"
            android:gravity="center" />

        <!-- Tombol Refresh sesuai spesifikasi teknis poin 6 -->
        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Coba Lagi (Refresh)"
            android:textColor="@color/cream_bg"
            android:backgroundTint="@color/brown_dark" />
    </LinearLayout>

</RelativeLayout>