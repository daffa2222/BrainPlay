<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream_bg"
    android:padding="24dp">

    <!-- Indikator Nomor Soal -->
    <TextView
        android:id="@+id/tvQuestionNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pertanyaan: 1 / 5"
        android:textColor="@color/brown_light"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />

    <!-- Komponen Box Soal (Card View) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/cream_card"
        android:padding="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/tvQuestionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ini adalah tempat teks pertanyaan kuis dari BrainPlay akan muncul?"
            android:textColor="@color/brown_dark"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <!-- Pilihan Jawaban A -->
    <Button
        android:id="@+id/btnOptionA"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Pilihan Jawaban A"
        android:textColor="@color/brown_dark"
        android:backgroundTint="@color/cream_accent"
        android:layout_marginBottom="12dp"
        android:textAllCaps="false" />

    <!-- Pilihan Jawaban B -->
    <Button
        android:id="@+id/btnOptionB"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Pilihan Jawaban B"
        android:textColor="@color/brown_dark"
        android:backgroundTint="@color/cream_accent"
        android:layout_marginBottom="12dp"
        android:textAllCaps="false" />

    <!-- Pilihan Jawaban C -->
    <Button
        android:id="@+id/btnOptionC"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Pilihan Jawaban C"
        android:textColor="@color/brown_dark"
        android:backgroundTint="@color/cream_accent"
        android:layout_marginBottom="12dp"
        android:textAllCaps="false" />

    <!-- Pilihan Jawaban D -->
    <Button
        android:id="@+id/btnOptionD"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Pilihan Jawaban D"
        android:textColor="@color/brown_dark"
        android:backgroundTint="@color/cream_accent"
        android:layout_marginBottom="32dp"
        android:textAllCaps="false" />

</LinearLayout>